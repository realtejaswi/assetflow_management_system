# ============================================================
# AssetFlow Ecosystem — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# ── MongoDB ──────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=assetflow
MONGO_PASSWORD=assetflow123
MONGO_AUTH_DB=admin

BANK_DB_NAME=bank_simulator
ASSETFLOW_DB_NAME=assetflow

BANK_MONGO_URI=mongodb://assetflow:assetflow123@localhost:27017/bank_simulator?authSource=admin
ASSETFLOW_MONGO_URI=mongodb://assetflow:assetflow123@localhost:27017/assetflow?authSource=admin

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Redis channels
BANK_EVENT_CHANNEL=bank_events
BANK_TRANSACTION_CHANNEL=bank_transactions
BANK_LOAN_CHANNEL=bank_loans
BANK_INVESTMENT_CHANNEL=bank_investments

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Bank Simulator Backend ────────────────────────────────────
BANK_BACKEND_HOST=localhost
BANK_BACKEND_PORT=8001
BANK_BACKEND_URL=http://localhost:8001

# ── AssetFlow Backend ─────────────────────────────────────────
ASSETFLOW_BACKEND_HOST=localhost
ASSETFLOW_BACKEND_PORT=8002
ASSETFLOW_BACKEND_URL=http://localhost:8002

# ── AssetFlow API Gateway ─────────────────────────────────────
API_GATEWAY_HOST=localhost
API_GATEWAY_PORT=8000
API_GATEWAY_URL=http://localhost:8000

# ── Microservice Ports ────────────────────────────────────────
CONSUMER_SERVICE_PORT=8003
ETL_SERVICE_PORT=8004
ML_SERVICE_PORT=8005
AI_SERVICE_PORT=8006
TAX_SERVICE_PORT=8007
NOTIFICATION_SERVICE_PORT=8008

# ── Ollama / AI Service ───────────────────────────────────────
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3
OLLAMA_TIMEOUT=120

# ── Frontend URLs (used by React apps) ───────────────────────
VITE_BANK_API_URL=http://localhost:8001
VITE_ASSETFLOW_API_URL=http://localhost:8000
VITE_ASSETFLOW_WS_URL=ws://localhost:8008

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:5174
